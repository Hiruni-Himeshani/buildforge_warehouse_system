# ============================================
# DATABASE CONFIGURATION
# ============================================
MONGO_URI=mongodb://localhost:27017/buildforge_wms
# For MongoDB Atlas Cloud: mongodb+srv://username:password@cluster.mongodb.net/buildforge_wms

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5001
NODE_ENV=development

# ============================================
# JWT & AUTHENTICATION
# ============================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRY=7d

# ============================================
# EMAIL CONFIGURATION (Nodemailer)
# ============================================
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_or_gmail_token
EMAIL_SERVICE=gmail
EMAIL_FROM=noreply@buildforge.com

# ============================================
# SMS CONFIGURATION (Twilio) - OPTIONAL
# Leave empty to disable SMS features
# Get credentials from: https://www.twilio.com/console
# ============================================
TWILIO_ACCOUNT_SID=AC_YOUR_ACCOUNT_ID_HERE
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# FRONTEND URL (for CORS)
# ============================================
FRONTEND_URL=http://localhost:3000
